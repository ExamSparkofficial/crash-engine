# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-secret

# Google OAuth for NextAuth. Leave blank to run with credentials auth disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL via Prisma. If omitted, the app runs with a safe in-memory demo store.
DATABASE_URL=postgresql://crashpulse:crashpulse@localhost:5432/crashpulse?schema=public

# Optional live data source. Only connect to data feeds you are authorized to use.
CRASH_SOURCE_WS=
CRASH_SOURCE_POLL_URL=
CRASH_SOURCE_POLL_INTERVAL_MS=5000

# Optional Python analytics microservice.
ANALYTICS_SERVICE_URL=http://localhost:8000

# Security and realtime
SOCKET_ALLOWED_ORIGINS=http://localhost:3000
API_RATE_LIMIT=120
